    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0"
  },
  "devDependencies": {
    "esbuild": "0.21.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "lucide-react": "0.383.0"
  }
}